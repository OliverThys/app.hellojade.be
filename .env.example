# ─── Application ──────────────────────────────────────────────────────────────
APP_ENV=production
APP_DEBUG=false
APP_DOMAIN=app.hellojadeapp.be
FRONTEND_URL=https://app.hellojadeapp.be
SECRET_KEY=change_me_with_openssl_rand_hex_32

# ─── Base de données PostgreSQL ───────────────────────────────────────────────
POSTGRES_PASSWORD=change_me

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=change_me

# ─── Azure Cognitive Services (STT + TTS) ────────────────────────────────────
AZURE_SPEECH_KEY=your_azure_speech_key_here
AZURE_SPEECH_REGION=westeurope
AZURE_STT_LANGUAGE=fr-BE
AZURE_TTS_VOICE=fr-BE-CharlineNeural

# ─── Mistral API ──────────────────────────────────────────────────────────────
MISTRAL_API_KEY=your_mistral_api_key_here
MISTRAL_MODEL=mistral-small-latest

# ─── Asterisk ARI ─────────────────────────────────────────────────────────────
ASTERISK_ARI_URL=http://localhost:8088
ASTERISK_ARI_USER=hellojadeapp
ASTERISK_ARI_PASSWORD=change_me
ASTERISK_ARI_APP=hellojadeapp
ASTERISK_CALLER_NUMBER=+3200000000
ASTERISK_TRUNK=ovh-trunk

# ─── Voix / Appels ────────────────────────────────────────────────────────────
VOICE_BARGE_IN_ENABLED=true
TRANSFER_MODE=sip
TRANSFER_NUMBER=+3200000000

# ─── Keycloak / SSO ───────────────────────────────────────────────────────────
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=change_me
KEYCLOAK_DB_PASSWORD=change_me

# ─── Cloudflare Tunnel ────────────────────────────────────────────────────────
CLOUDFLARE_TUNNEL_TOKEN=your_cloudflare_tunnel_token_here

# ─── Mirth Connect / HL7 ──────────────────────────────────────────────────────
MIRTH_TRANSPORT=sftp
MIRTH_HTTP_URL=http://mirth:8080

# ─── Monitoring ───────────────────────────────────────────────────────────────
PROMETHEUS_ENABLED=true
GRAFANA_PASSWORD=change_me

# ─── RGPD ─────────────────────────────────────────────────────────────────────
GDPR_CONSENT_REQUIRED=true
GDPR_DATA_RETENTION_YEARS=5
